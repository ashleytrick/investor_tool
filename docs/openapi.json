{
  "openapi": "3.1.0",
  "info": {
    "title": "Investor Outreach API",
    "description": "Backend for the external React frontend (`awesome_investor_tool`). All mutating endpoints shell out to the matching scripts/*.py so the existing workspace lock + audit + backup story is preserved.",
    "version": "1.0.0"
  },
  "paths": {
    "/review/pending": {
      "get": {
        "tags": [
          "review"
        ],
        "summary": "Drafts pending operator review",
        "operationId": "get_pending_review_pending_get",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DraftView"
                  },
                  "title": "Response Get Pending Review Pending Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/drafts/approved": {
      "get": {
        "tags": [
          "review"
        ],
        "summary": "Drafts ready to send (approved live rows)",
        "operationId": "get_approved_drafts_approved_get",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DraftView"
                  },
                  "title": "Response Get Approved Drafts Approved Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/drafts/{draft_id}/approve": {
      "post": {
        "tags": [
          "mutations"
        ],
        "summary": "Approve a draft (shells out to approve_draft.py)",
        "operationId": "approve_draft_drafts__draft_id__approve_post",
        "parameters": [
          {
            "name": "draft_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Draft Id"
            }
          },
          {
            "name": "authorization",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApproveBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommandResult"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/drafts/{draft_id}/reject": {
      "post": {
        "tags": [
          "mutations"
        ],
        "summary": "Reject a draft (shells out to reject_draft.py)",
        "operationId": "reject_draft_drafts__draft_id__reject_post",
        "parameters": [
          {
            "name": "draft_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Draft Id"
            }
          },
          {
            "name": "authorization",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RejectBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommandResult"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/partners/{partner_id}/email": {
      "post": {
        "tags": [
          "mutations"
        ],
        "summary": "Set a partner's email (shells out to set_partner_email.py)",
        "operationId": "set_partner_email_partners__partner_id__email_post",
        "parameters": [
          {
            "name": "partner_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Partner Id"
            }
          },
          {
            "name": "authorization",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetEmailBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommandResult"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/check_ready": {
      "get": {
        "tags": [
          "status"
        ],
        "summary": "Pre-flight check (review|send|gmail|attio)",
        "operationId": "check_ready_check_ready_get",
        "parameters": [
          {
            "name": "phase",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^(review|send|gmail|attio)$",
              "description": "Which workflow phase to gate on.",
              "default": "send",
              "title": "Phase"
            },
            "description": "Which workflow phase to gate on."
          },
          {
            "name": "authorization",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckReadyResult"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/runs": {
      "get": {
        "tags": [
          "status"
        ],
        "summary": "Recent run entries",
        "operationId": "get_runs_runs_get",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 500,
              "minimum": 1,
              "default": 50,
              "title": "Limit"
            }
          },
          {
            "name": "authorization",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RunRow"
                  },
                  "title": "Response Get Runs Runs Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/send_queue.csv": {
      "get": {
        "tags": [
          "export"
        ],
        "summary": "Build + download the send_queue CSV",
        "description": "Calls export_send_queue.py to materialize the CSV, then\nstreams the file. Returns 400 if the export refuses (e.g. no\napproved drafts; stale approvals not skipped).",
        "operationId": "send_queue_csv_send_queue_csv_get",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              },
              "text/csv": {}
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApproveBody": {
        "properties": {
          "notes": {
            "type": "string",
            "minLength": 1,
            "title": "Notes",
            "description": "Operator rationale; required for audit."
          },
          "override_blockers": {
            "type": "boolean",
            "title": "Override Blockers",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "notes"
        ],
        "title": "ApproveBody"
      },
      "BlockerInfo": {
        "properties": {
          "text": {
            "type": "string",
            "title": "Text"
          },
          "severity": {
            "type": "string",
            "title": "Severity"
          }
        },
        "type": "object",
        "required": [
          "text",
          "severity"
        ],
        "title": "BlockerInfo"
      },
      "CheckReadyResult": {
        "properties": {
          "phase": {
            "type": "string",
            "title": "Phase"
          },
          "stdout": {
            "type": "string",
            "title": "Stdout"
          },
          "blocked": {
            "type": "boolean",
            "title": "Blocked"
          },
          "return_code": {
            "type": "integer",
            "title": "Return Code"
          }
        },
        "type": "object",
        "required": [
          "phase",
          "stdout",
          "blocked",
          "return_code"
        ],
        "title": "CheckReadyResult"
      },
      "CommandResult": {
        "properties": {
          "ok": {
            "type": "boolean",
            "title": "Ok"
          },
          "stdout": {
            "type": "string",
            "title": "Stdout"
          },
          "stderr": {
            "type": "string",
            "title": "Stderr",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "ok",
          "stdout"
        ],
        "title": "CommandResult"
      },
      "DraftView": {
        "properties": {
          "draft_id": {
            "type": "integer",
            "title": "Draft Id"
          },
          "partner_id": {
            "type": "string",
            "title": "Partner Id"
          },
          "strategy": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Strategy"
          },
          "subject": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Subject"
          },
          "body": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Body"
          },
          "approval_status": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Approval Status"
          },
          "qa_status": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Qa Status"
          },
          "template_smell": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Template Smell"
          },
          "partner_email": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Partner Email"
          },
          "gate": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/GateInfo"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "type": "object",
        "required": [
          "draft_id",
          "partner_id"
        ],
        "title": "DraftView"
      },
      "GateInfo": {
        "properties": {
          "ok": {
            "type": "boolean",
            "title": "Ok"
          },
          "blockers": {
            "items": {
              "$ref": "#/components/schemas/BlockerInfo"
            },
            "type": "array",
            "title": "Blockers"
          },
          "overridden": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Overridden"
          }
        },
        "type": "object",
        "required": [
          "ok",
          "blockers",
          "overridden"
        ],
        "title": "GateInfo"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "RejectBody": {
        "properties": {
          "notes": {
            "type": "string",
            "minLength": 1,
            "title": "Notes"
          }
        },
        "type": "object",
        "required": [
          "notes"
        ],
        "title": "RejectBody"
      },
      "RunRow": {
        "properties": {
          "run_id": {
            "type": "integer",
            "title": "Run Id"
          },
          "stage": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Stage"
          },
          "started_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Started At"
          },
          "completed_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Completed At"
          },
          "processed": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Processed"
          },
          "succeeded": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Succeeded"
          },
          "failed": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Failed"
          },
          "skipped": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Skipped"
          },
          "error_summary": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Summary"
          }
        },
        "type": "object",
        "required": [
          "run_id",
          "stage",
          "started_at",
          "completed_at",
          "processed",
          "succeeded",
          "failed",
          "skipped",
          "error_summary"
        ],
        "title": "RunRow"
      },
      "SetEmailBody": {
        "properties": {
          "email": {
            "type": "string",
            "minLength": 3,
            "title": "Email"
          }
        },
        "type": "object",
        "required": [
          "email"
        ],
        "title": "SetEmailBody"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}