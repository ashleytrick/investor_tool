# Repo-root shared keys. Copy to .env and fill in.
# Workspace-specific keys live in clients/{workspace}/.env and override these.

# Shared enrichment / LLM keys.
# NOTE: each operator should supply their own ANTHROPIC_API_KEY (in this file
# or in clients/{workspace}/.env) so API spend is attributed per operator.
ANTHROPIC_API_KEY=

# Optional shared enrichment APIs.
LISTENNOTES_API_KEY=
